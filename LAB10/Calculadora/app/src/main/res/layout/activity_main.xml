<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculadora en Kotlin"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etNumero1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese el primer número"
            android:inputType="numberDecimal|numberSigned" />

        <EditText
            android:id="@+id/etNumero2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese el segundo número"
            android:inputType="numberDecimal|numberSigned"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnSuma"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sumar"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnResta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restar" />

        <Button
            android:id="@+id/btnMultiplicacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Multiplicar" />

        <Button
            android:id="@+id/btnDivision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dividir" />

        <Button
            android:id="@+id/btnPotencia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Potencia" />

        <Button
            android:id="@+id/btnRaiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Raíz cuadrada del primer número" />

        <Button
            android:id="@+id/btnRaiz2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Raíz cuadrada del segundo número" />

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resultado:"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>